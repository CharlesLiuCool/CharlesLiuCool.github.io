---
import { SITE, NAV } from '../../config/site';

const { currentPath = '' } = Astro.props;

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath.startsWith(href);
}
---

<aside class="sidebar">

  <!-- Brand -->
  <div class="sidebar-header">
    <a href="/" class="sidebar-brand">
      <div class="sidebar-brand-icon">
        <img
          src="/images/dark_logo.png"
          alt={SITE.name}
          class="sidebar-brand-image"
        />
      </div>
      <div>
        <div class="sidebar-brand-name">{SITE.name}</div>
        <div class="sidebar-brand-role">{SITE.role}</div>
      </div>
    </a>
    <div class="sidebar-status">
      <span class="status-dot status-dot--green status-dot--pulse"></span>
    
      <span class="sidebar-status-text">
        <span class="tagline-wrap">
          <span id="tagline" class="tagline-text">
            {SITE.taglines[0]}
          </span>
        </span>
      </span>
    </div>
  </div>

  <!-- Nav -->
  <nav class="sidebar-nav">
    {NAV.map(group => (
      <div>
        <div class="nav-group-label">{group.label}</div>
        <ul class="nav-list">
          {group.items.map(item => (
            <li>
              <a
                href={item.href}
                class:list={['nav-link', { 'is-active': isActive(item.href) }]}
              >
                <span class="nav-link__icon">{item.icon}</span>
                <span>{item.label}</span>
                {isActive(item.href) && <span class="nav-link__dot"></span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>

  <!-- Footer -->
  <div class="sidebar-footer">
    <div class="social-links">
      <a href={SITE.github}  target="_blank" rel="noopener" class="social-link" title="GitHub">
        <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
        </svg>
      </a>
      <a href={SITE.youtube} target="_blank" rel="noopener" class="social-link" title="YouTube">
        <svg width="15" height="15" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M23.498 6.186a2.997 2.997 0 00-2.11-2.12C19.505 3.5 12 3.5 12 3.5s-7.505 0-9.388.566a2.997 2.997 0 00-2.11 2.12C0 8.078 0 12 0 12s0 3.922.502 5.814a2.997 2.997 0 002.11 2.12C4.495 20.5 12 20.5 12 20.5s7.505 0 9.388-.566a2.997 2.997 0 002.11-2.12C24 15.922 24 12 24 12s0-3.922-.502-5.814zM9.75 15.568V8.432L15.818 12 9.75 15.568z"/>
        </svg>
      </a>
      <a href={`mailto:${SITE.email}`} class="social-link" title="Email">
        <svg width="15" height="15" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
        </svg>
      </a>
    </div>
    <div class="version-tag" style="margin-top: var(--space-3);">v0.1.0</div>
  </div>

</aside>

<!--Script to rotate tagline -->
<script is:inline define:vars={{ taglines: SITE.taglines }}>
  let i = 0;
  const el = document.getElementById("tagline");

  function swapText(text) {
    if (!el) return;

    el.classList.add("fade-out");

    setTimeout(() => {
      el.textContent = text;

      el.classList.remove("fade-out");
      el.classList.add("fade-in");

      requestAnimationFrame(() => {
        el.classList.remove("fade-in");
      });
    }, 500);
  }

  setInterval(() => {
    i = (i + 1) % taglines.length;
    swapText(taglines[i]);
  }, 5000);
</script>