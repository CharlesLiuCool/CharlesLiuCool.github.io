---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../config/site';

const interests = [
  { area: 'Zero-Knowledge Proofs', detail: 'SNARKs, STARKs, proof composition' },
  { area: 'Interactive Proofs',    detail: 'Sum-check, MIPs, PCPs' },
  { area: 'Commitment Schemes',    detail: 'KZG, FRI, Pedersen' },
  { area: 'Complexity Theory',     detail: 'IP, PSPACE, #P' },
];
---

<BaseLayout title="About">
  <div class="page-container animate-fade-up">

    <div class="page-header">
      <div class="page-header__title-row">
        <h1 class="heading-section">About</h1>
      </div>
      <p class="page-header__description">The person behind the research.</p>
    </div>

    <div class="about-grid" style="display:grid;grid-template-columns:1fr 200px;gap:var(--space-10);align-items:start;">

      <!-- Bio -->
      <div class="stack stack--lg about-bio">
        <p>
          I'm an undergraduate interested in theoretical computer science,
          particularly <em>cryptography</em>. I am a research assistant in the
          Dr. Feng-hao Liu lab, where I study post-quantum cryptography,
          fully homomorphic encryption, and zero-knowledge proofs.
        </p>
        <p>
          Outside of research, I am a software engineer intern at Schweitzer
          Engineering Laboratories.
        </p>
        <p>
          In my free time, I enjoy bird-watching, tennis, and chess.
        </p>

        <!-- Research interests -->
        <div>
          <div class="label-section" style="margin-bottom:var(--space-4);">Research Interests</div>
          <div class="stack stack--sm">
            {interests.map(({ area, detail }) => (
              <div class="interest-row">
                <span class="interest-row__area">{area}</span>
                <span class="interest-row__detail">{detail}</span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Sidebar info -->
      <div class="stack stack--lg">
        <div>
          <div class="label-section" style="margin-bottom:var(--space-3);">Contact</div>
          <div class="stack stack--sm">
            <div>
              <div class="label-meta">email</div>
              <a href={`mailto:${SITE.email}`} class="about-contact-link">{SITE.email}</a>
            </div>
            <div>
              <div class="label-meta">github</div>
              <a href={SITE.github} class="about-contact-link">@{SITE.github_name}</a>
            </div>
            <div>
              <div class="label-meta">youtube</div>
              <a href={SITE.youtube} class="about-contact-link">@{SITE.youtube_name}</a>
            </div>
          </div>
        </div>

        <div>
          <div class="label-section" style="margin-bottom:var(--space-3);">Affiliation</div>
          <div class="stack stack--sm" style="font-size:var(--text-sm);">
            <div style="color:var(--text-primary);font-weight:500;">{SITE.institution}</div>
            <div class="label-meta">Feng-hao Liu Cryptography Lab</div>
            <div class="label-meta">Pullman, WA USA</div>
          </div>
        </div>

        <a href="/cv" class="btn btn--purple">View CV →</a>
      </div>

    </div>
  </div>

  <style>
    .about-bio p {
      font-family: var(--font-serif);
      font-size: var(--text-md);
      color: var(--text-secondary);
      line-height: var(--leading-loose);
    }
    .about-bio em {
      font-style: italic;
      color: var(--accent);
    }

    .interest-row {
      display: flex;
      align-items: baseline;
      gap: var(--space-3);
      padding: var(--space-2) 0;
      border-bottom: 1px solid var(--border-faint);
    }
    .interest-row:last-child { border-bottom: none; }
    .interest-row__area {
      font-family: var(--font-heading);
      font-weight: 600;
      font-size: var(--text-base);
      color: var(--text-primary);
      flex-shrink: 0;
    }
    .interest-row__detail {
      font-size: var(--text-sm);
      color: var(--text-muted);
      margin-left: auto;
      text-align: right;
    }

    .about-contact-link {
      font-size: var(--text-sm);
      color: var(--accent);
      transition: color var(--transition-base);
      word-break: break-word;
    }
    .about-contact-link:hover { color: var(--accent-strong); }

    @media (max-width: 768px) {
      .about-grid { grid-template-columns: 1fr !important; }
    }
  </style>
</BaseLayout>
