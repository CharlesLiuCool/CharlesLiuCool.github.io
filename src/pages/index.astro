---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContentCard from '../components/ui/ContentCard.astro';
import Section from '../components/ui/Section.astro';
import { SITE, HOME_SECTIONS } from '../config/site';
import { getCollection } from 'astro:content';

const research = await getCollection('research');
const notes    = await getCollection('notes');
const blog     = await getCollection('blog');

const collections: Record<string, typeof research> = { research, notes, blog };

// Resolve each homepage section to its items
const sections = HOME_SECTIONS.map(sec => {
  let items = collections[sec.collection] ?? [];
  if ('filterBy' in sec && sec.filterBy) {
    for (const [key, val] of Object.entries(sec.filterBy)) {
      items = items.filter((i: any) => i.data[key] === val);
    }
  }
  items = items
    .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
    .slice(0, sec.limit);
  return { ...sec, items };
});
---

<BaseLayout title="Home" description={SITE.description}>
  <div class="page-container animate-fade-up">

    <!-- Hero -->
    <section class="page-section hero">
      <p class="hero-eyebrow">{SITE.role} · {SITE.institution}</p>

      <h1 class="hero-title">{SITE.name}</h1>

      <p class="hero-body">
        I work on post-quantum cryptography, with emphasis on cryptographic
        protocols and zero-knowledge proofs, and I'm drawn to the foundations
        of theoretical computer science.
      </p>

      <div class="hero-tags">
        {['zero-knowledge', 'interactive proofs', 'sum-check', 'low-degree extensions', 'commitment schemes'].map(t => (
          <span class="tag">{t}</span>
        ))}
      </div>
    </section>

    <!-- Dynamic homepage sections -->
    {sections.map(sec => sec.items.length > 0 && (
      <Section
        title={sec.title}
        href={sec.href}
        accentVar={sec.accentVar}
        layout={sec.layout}
      >
        {sec.items.map((item: any) => (
          <ContentCard
            href={`/${sec.collection}/${item.id}`}
            title={item.data.title}
            date={item.data.date}
            summary={item.data.summary}
            tags={item.data.tags}
            status={item.data.status}
          />
        ))}
      </Section>
    ))}

  </div>
</BaseLayout>
