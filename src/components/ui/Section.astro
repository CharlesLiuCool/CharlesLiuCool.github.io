---
interface Props {
  title: string;
  href?: string;
  accentVar?: string;
  layout?: 'list' | 'grid';
}

const {
  title,
  href,
  accentVar = 'var(--accent-purple)',
  layout = 'list',
} = Astro.props;
---

<section class="page-section">
  <div class="section-header">
    <div class="section-header__left">
      <h2 class="section-title">{title}</h2>
    </div>
    {href && (
      <a href={href} class="section-more">all →</a>
    )}
  </div>

  <div class:list={[layout === 'grid' ? 'grid-auto-cards' : 'stack stack--md']}>
    <slot />
  </div>
</section>
