---
import { STATUS_CLASS, formatDate } from '../../config/site';

interface Props {
  href: string;
  title: string;
  date?: string;
  authors?: string[];
  summary?: string;
  tags?: string[];
  status?: string;
  meta?: string;
}

const { href, title, date, authors, summary, tags = [], status, meta } = Astro.props;
const statusClass = status ? (STATUS_CLASS[status] ?? 'badge--draft') : null;
---

<article class="card card--link">
  <div class="card__header">
    <a href={href} class="heading-card card__title-link">{title}</a>
    {statusClass && (
      <span class:list={['badge', statusClass]}>{status}</span>
    )}
  </div>

  {authors && authors.length > 0 && (
    <p class="card__authors">
      {authors.join(', ')}
    </p>
  )}
  {summary && <p class="card__summary">{summary}</p>}

  <div class="card__footer">
    <div class="card__tags">
      {tags.slice(0, 4).map(tag => (
        <a href={`/tags/${tag}`} class="tag">{tag}</a>
      ))}
    </div>
    <div class="card__meta">
      {meta  && <span class="label-meta">{meta}</span>}
      {date  && <span class="label-meta">{formatDate(date)}</span>}
    </div>
  </div>
</article>
