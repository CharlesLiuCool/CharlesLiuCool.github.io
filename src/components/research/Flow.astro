---
/*
  Flow.astro — a layered architecture / data-flow diagram.
  Stacks "layers" of nodes top-to-bottom and draws connectors between them
  (auto: parallel when counts match, merge when narrowing to one, split when
  widening from one). Theme-aware via design tokens; no client JS.

  Props:
    layers: Layer[]
      Layer = {
        group?: string          // optional label bracketing a row of parallel nodes
        nodes: Node[]
      }
      Node = {
        label: string
        sub?: string            // plain-text sub-label
        subTex?: string         // KaTeX sub-label (rendered at build time)
        variant?: 'default' | 'accent' | 'store' | 'muted'
      }
*/
import katex from 'katex';

interface Node {
  label: string;
  sub?: string;
  subTex?: string;
  variant?: 'default' | 'accent' | 'store' | 'muted';
}
interface Layer {
  group?: string;
  nodes: Node[];
}
interface Props {
  layers: Layer[];
}

const { layers } = Astro.props;

const tex = (s?: string) =>
  s ? katex.renderToString(s, { throwOnError: false, displayMode: false }) : '';

// centre x (in %) of slot i out of n evenly-spaced columns
const cx = (i: number, n: number) => ((i + 0.5) / n) * 100;

// connector line endpoints [x1%, x2%] between a top row of `t` nodes and bottom row of `b`
function edges(t: number, b: number): [number, number][] {
  if (b === 1) return Array.from({ length: t }, (_, i) => [cx(i, t), 50]);
  if (t === 1) return Array.from({ length: b }, (_, j) => [50, cx(j, b)]);
  const n = Math.max(t, b);
  return Array.from({ length: n }, (_, i) => [
    cx(Math.min(i, t - 1), t),
    cx(Math.min(i, b - 1), b),
  ]);
}
---

<div class="flow not-prose">
  <svg width="0" height="0" class="flow__defs" aria-hidden="true">
    <defs>
      <marker id="flow-arrow" viewBox="0 0 10 10" refX="8" refY="5"
        markerWidth="7" markerHeight="7" orient="auto">
        <path d="M0,0 L10,5 L0,10 z" class="flow__arrowhead" />
      </marker>
    </defs>
  </svg>

  {layers.map((layer, li) => (
    <>
      <div class:list={['flow__layer', layer.group && 'flow__layer--grouped']}>
        {layer.group && <span class="flow__group-label">{layer.group}</span>}
        <div class="flow__row">
          {layer.nodes.map((node) => (
            <div class:list={['flow__node', `flow__node--${node.variant ?? 'default'}`]}>
              <span class="flow__node-label">{node.label}</span>
              {node.subTex && <span class="flow__node-sub" set:html={tex(node.subTex)} />}
              {node.sub && <span class="flow__node-sub">{node.sub}</span>}
            </div>
          ))}
        </div>
      </div>

      {li < layers.length - 1 && (
        <svg class="flow__conn" width="100%" height="44" preserveAspectRatio="none" aria-hidden="true">
          {edges(layer.nodes.length, layers[li + 1].nodes.length).map(([x1, x2]) => (
            <line x1={`${x1}%`} y1="1" x2={`${x2}%`} y2="38" marker-end="url(#flow-arrow)" />
          ))}
        </svg>
      )}
    </>
  ))}
</div>

<style>
  .flow {
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-md);
    background: var(--bg-card);
    padding: var(--space-6);
    margin: var(--space-6) 0;
    box-shadow: var(--shadow-sm);
  }
  .flow__defs { position: absolute; }

  /* ── Layers & rows ─────────────────────────────────── */
  .flow__layer { position: relative; }
  .flow__row {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: var(--space-3);
  }
  .flow__layer--grouped {
    border: 1px dashed var(--border-default);
    border-radius: var(--radius-md);
    padding: var(--space-5) var(--space-3) var(--space-3);
  }
  .flow__group-label {
    position: absolute;
    top: calc(-0.7 * var(--text-xs) - 1px);
    left: var(--space-3);
    background: var(--bg-card);
    padding: 0 var(--space-2);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--text-muted);
  }

  /* ── Nodes ─────────────────────────────────────────── */
  .flow__node {
    flex: 1 1 0;
    min-width: 130px;
    max-width: 220px;
    display: flex;
    flex-direction: column;
    gap: 3px;
    text-align: center;
    padding: var(--space-3) var(--space-3);
    background: var(--bg-surface);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-sm);
  }
  .flow__node-label {
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-primary);
    line-height: var(--leading-snug);
  }
  .flow__node-sub {
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .flow__node--accent {
    background: var(--accent-soft);
    border-color: var(--accent-line);
    box-shadow: inset 0 0 0 1px var(--accent-line);
    max-width: 320px;
  }
  .flow__node--accent .flow__node-label { color: var(--accent); font-weight: 600; }

  .flow__node--store {
    background: var(--bg-sunken);
    border-style: dashed;
  }
  .flow__node--store .flow__node-label { font-family: var(--font-mono); font-size: var(--text-xs); }

  .flow__node--muted {
    background: transparent;
    border-style: dashed;
    border-color: var(--border-default);
  }
  .flow__node--muted .flow__node-label { color: var(--text-muted); font-weight: 400; }

  /* ── Connectors ────────────────────────────────────── */
  .flow__conn { display: block; overflow: visible; }
  .flow__conn line { stroke: var(--border-default); stroke-width: 1.5; }
  .flow__arrowhead { fill: var(--border-default); }

  @media (max-width: 560px) {
    .flow__node { min-width: 100%; }
    .flow__conn { height: 28px; }
  }
</style>
